# Location for weather + briefing greeting
LOCATION_NAME="Brooklyn, NY"
LOCATION_LAT="40.6782"
LOCATION_LON="-73.9442"

# Google OAuth (Gmail)
# 1. Create credentials at https://console.cloud.google.com/apis/credentials
# 2. Set authorized redirect URI to:  http://localhost:3000/api/auth/gmail/callback
#    (and your prod URL, e.g. https://YOUR.vercel.app/api/auth/gmail/callback)
# 3. Enable the Gmail API
# 4. Run dev, visit /api/auth/gmail/start, complete consent, copy the refresh token
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_REDIRECT_URI="http://localhost:3000/api/auth/gmail/callback"
GMAIL_REFRESH_TOKEN=""

# News
# Comma-separated RSS feed URLs for local news
LOCAL_NEWS_FEEDS="https://feeds.npr.org/1001/rss.xml,https://www.brooklynpaper.com/feed/"
# How many AI stories to fetch from Hacker News
AI_NEWS_LIMIT="5"
# How many local stories
LOCAL_NEWS_LIMIT="5"
